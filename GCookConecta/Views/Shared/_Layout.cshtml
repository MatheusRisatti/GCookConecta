<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GCookConecta | @ViewData["Title"]</title>
    <!-- Font Awesome para ícones (profile, config, etc) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/css/darkStyle.css">
</head>
<body>
    <!-- NAVBAR com usuário e dropdown -->
    <nav class="navbar">
        <a asp-action="Index" class="logo-area">
            <div class="logo-icon">
                <img src="~/img/logo.png" alt="logo" width="50">
            </div>
            <div class="logo-text">GCook</div>
        </a>

        <div class="profile-section">
            <div class="profile-preview">
                <!-- Imagem do usuário logada: usaremos uma foto ilustrativa (logado) -->
                <img class="avatar-img" src="~/img/usuarios/no-photo.png" alt="Avatar da Ana">
                <div class="user-info">
                    <div class="user-name">Usuário não logado</div>
                    <div class="user-role"><i class="fas fa-chef-hat"></i> chef de cozinha</div>
                </div>
            </div>
            <!-- Menu suspenso -->
            <div class="dropdown-menu">
                <div class="dropdown-item"><i class="fas fa-user"></i> Meu perfil</div>
                <div class="dropdown-item"><i class="fas fa-sliders-h"></i> Configurações</div>
                <div class="dropdown-item"><i class="fas fa-sign-out-alt"></i> Sair</div>
            </div>
        </div>
    </nav>

    <main class="container">
        @RenderBody()
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>