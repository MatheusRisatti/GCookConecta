@{
    ViewData["Title"] = "Login";
    ViewData["mainClass"] = "login-container";
}

@section Styles {
    <link rel="stylesheet" href="~/css/login.css">
    }

<div class="login-card">
    <div class="login-header">
        <div class="logo-icon-large">
            <i class="fas fa-utensils"></i>
        </div>
        <h1>Bem-vindo de volta</h1>
        <p>Entre para compartilhar e descobrir receitas incríveis</p>
    </div>

    <!-- mensagem de alerta (simulação) -->
    <div class="alert-message" id="alertMessage">
        <i class="fas fa-info-circle"></i>
        <span id="alertText"></span>
    </div>

    <form id="loginForm" onsubmit="event.preventDefault(); handleLogin()">
        <div class="form-group">
            <label><i class="fas fa-envelope"></i> E-mail</label>
            <div class="input-wrapper">
                <i class="fas fa-envelope"></i>
                <input type="email" class="form-control" placeholder="seu@email.com" id="email" required>
            </div>
        </div>

        <div class="form-group">
            <label><i class="fas fa-lock"></i> Senha</label>
            <div class="password-wrapper">
                <div class="input-wrapper">
                    <i class="fas fa-lock"></i>
                    <input type="password" class="form-control" placeholder="••••••••" id="password" required>
                </div>
                <button type="button" class="toggle-password" onclick="togglePassword()">
                    <i class="fas fa-eye"></i>
                </button>
            </div>
        </div>

        <div class="form-options">
            <label class="remember-me">
                <input type="checkbox"> Lembrar-me
            </label>
            <a href="#" class="forgot-password">Esqueceu a senha?</a>
        </div>

        <button type="submit" class="btn-login">
            <i class="fas fa-sign-in-alt"></i> Entrar
        </button>

        <div class="signup-prompt">
            Ainda não tem conta?
            <a href="#">Cadastre-se</a>
        </div>
    </form>

</div>

<!-- dica extra -->
<div style="text-align: center; margin-top: 2rem; color: #7e6f60; font-size: 0.9rem;">
    <i class="fas fa-shield-alt" style="color: var(--verde-alface);"></i>
    Seus dados estão seguros · GCook respeita sua privacidade
</div>